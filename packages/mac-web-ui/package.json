{
  "name": "@voiceclaw/mac-web-ui",
  "version": "0.1.0",
  "description": "Real-time voice agent dashboard",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run dev-server.ts",
    "build": "bun build ./index.html --outdir=dist --env='PUBLIC_*'",
    "preview": "bun run --production dev-server.ts",
    "typecheck": "bun run tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.12",
    "ai": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "ghostty-web": "^0.4.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "streamdown": "^1.6.10",
    "tailwind-merge": "^3.4.0",
    "use-stick-to-bottom": "^1.1.1",
    "zustand": "^5.0.9"
  }
