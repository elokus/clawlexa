{
  "name": "pi-agent",
  "version": "1.0.0",
  "description": "TypeScript realtime voice agent for Raspberry Pi",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "test:text": "bun run src/test-text.ts",
    "test:db": "bun run src/test-db.ts",
    "test:timer": "bun run src/test-timer.ts",
    "scratch:voice": "bun run src/scratch-voice-pipeline.ts",
    "scratch:benchmark": "bun run src/scratch-voice-benchmark.ts",
    "scratch:provider": "bun run src/scratch-provider-contract.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "bun run tsc --noEmit"
  },
  "keywords": [
    "voice-agent",
    "openai",
    "realtime",
    "raspberry-pi"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@voiceclaw/voice-runtime": "workspace:*",
    "@openai/agents": "^0.3.4",
    "@openrouter/ai-sdk-provider": "^1.4.1",
    "@picovoice/porcupine-node": "^3.0.6",
    "@picovoice/pvrecorder-node": "^1.2.8",
    "ai": "^5.0.108",
    "dotenv": "^17.2.3",
    "node-record-lpcm16": "^1.0.1",
    "openai": "^6.10.0",
    "ws": "^8.18.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.8",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  }
}
